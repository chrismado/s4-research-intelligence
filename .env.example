# S4 Research Intelligence — Environment Configuration
# Copy to .env and modify as needed.

# LLM provider: "ollama" (local), "openai", or "aws_bedrock"
S4RI_LLM_PROVIDER=ollama
S4RI_LLM_MODEL=mistral:7b-instruct-v0.3-q5_K_M
S4RI_LLM_BASE_URL=http://localhost:11434
S4RI_LLM_TEMPERATURE=0.1
S4RI_LLM_NUM_GPU=-1  # -1 = auto, 0 = CPU only (use 0 if GPU is busy)

# Embedding model (runs locally via sentence-transformers)
S4RI_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
S4RI_EMBEDDING_DEVICE=cpu

# Vector store
S4RI_CHROMA_COLLECTION=s4_research

# Retrieval settings
S4RI_RETRIEVAL_TOP_K=8
S4RI_RERANK_ENABLED=true
S4RI_RERANK_TOP_N=5

# Chunking
S4RI_CHUNK_SIZE=1000
S4RI_CHUNK_OVERLAP=200

# API
S4RI_API_PORT=8000
S4RI_LOG_LEVEL=INFO

# Hybrid search
S4RI_HYBRID_SEARCH_ENABLED=true
S4RI_HYBRID_SEMANTIC_WEIGHT=0.7
S4RI_HYBRID_KEYWORD_WEIGHT=0.3
